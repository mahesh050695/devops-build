pipeline {
    agent any

    environment {
        DEV_IMAGE = "mk5695/dev:latest"
        PROD_IMAGE = "mk5695/prod:latest"
        DOCKERHUB_CREDENTIALS = 'dockerhub-creds'
    }

    stages {

        stage('Detect Branch') {
            steps {
                script {
                    branch = sh(
                        script: "git rev-parse --abbrev-ref HEAD",
                        returnStdout: true
                    ).trim()

                    echo "Branch detected: ${branch}"
                }
            }
        }

        stage('Build Image') {
            steps {
                script {
                    if (branch == "dev") {
                        sh "docker build -t $DEV_IMAGE ."
                    } else if (branch == "main") {
                        sh "docker build -t $PROD_IMAGE ."
                    } else {
                        error "Unknown branch: ${branch}"
                    }
                }
            }
        }

        stage('Docker Login') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: "$DOCKERHUB_CREDENTIALS",
                    usernameVariable: 'USERNAME',
                    passwordVariable: 'PASSWORD'
                )]) {
                    sh 'echo $PASSWORD | docker login -u $USERNAME --password-stdin'
                }
            }
        }

        stage('Push Image') {
            steps {
                script {
                    if (branch == "dev") {
                        sh "docker push $DEV_IMAGE"
                    } else if (branch == "main") {
                        sh "docker push $PROD_IMAGE"
                    }
                }
            }
        }

        stage('Deploy') {
            steps {
                script {
                    if (branch == "dev") {
                        sh '''
                        docker stop app || true
                        docker rm app || true
                        docker run -d -p 80:80 --name app $DEV_IMAGE
                        '''
                    } else if (branch == "main") {
                        sh '''
                        docker stop app || true
                        docker rm app || true
                        docker run -d -p 80:80 --name app $PROD_IMAGE
                        '''
                    }
                }
            }
        }
    }
}