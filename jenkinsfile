pipeline {
    agent any

    environment {
        DEV_IMAGE = "mk5695/dev:latest"
        PROD_IMAGE = "mk5695/prod:latest"
        DOCKERHUB_CREDENTIALS = 'dockerhub-creds'
    }

    stages {

        stage('Init') {
            steps {
                script {
                    def branch = env.BRANCH_NAME

                    if (!branch) {
                        branch = env.GIT_BRANCH
                    }

                    if (!branch) {
                        error "Branch not detected"
                    }

                    // normalize
                    branch = branch.replace("origin/", "")

                    env.ACTIVE_BRANCH = branch

                    echo "Branch detected: ${env.ACTIVE_BRANCH}"
                }
            }
        }

        stage('Build Image') {
            steps {
                script {
                    if (env.ACTIVE_BRANCH == "dev") {
                        sh "docker build -t $DEV_IMAGE ."
                    } else if (env.ACTIVE_BRANCH == "main") {
                        sh "docker build -t $PROD_IMAGE ."
                    } else {
                        error "Unknown branch: ${env.ACTIVE_BRANCH}"
                    }
                }
            }
        }

        stage('Docker Login') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: "$DOCKERHUB_CREDENTIALS",
                    usernameVariable: 'USERNAME',
                    passwordVariable: 'PASSWORD'
                )]) {
                    sh 'echo $PASSWORD | docker login -u $USERNAME --password-stdin'
                }
            }
        }

        stage('Push Image') {
            steps {
                script {
                    if (env.ACTIVE_BRANCH == "dev") {
                        sh "docker push $DEV_IMAGE"
                    } else if (env.ACTIVE_BRANCH == "main") {
                        sh "docker push $PROD_IMAGE"
                    }
                }
            }
        }

        stage('Deploy') {
            steps {
                script {
                    if (env.ACTIVE_BRANCH == "dev") {
                        sh '''
                        docker stop app || true
                        docker rm app || true
                        docker run -d -p 80:80 --name app $DEV_IMAGE
                        '''
                    } else if (env.ACTIVE_BRANCH == "main") {
                        sh '''
                        docker stop app || true
                        docker rm app || true
                        docker run -d -p 80:80 --name app $PROD_IMAGE
                        '''
                    }
                }
            }
        }
    }
}